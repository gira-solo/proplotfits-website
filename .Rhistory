state     = state,
county    = counties,
survey    = 'acs5',
year      = 2022,
geometry  = TRUE
)
}
kc_mo <- pull_spanish_speakers("MO", kc_counties$MO)
kc_ks <- pull_spanish_speakers("KS", kc_counties$KS)
kc_mo
library(tidycensus)
vars <- load_variables(2022, "acs5", cache = TRUE)
vars |> dplyr::filter(grepl("B16001", name)) |> dplyr::select(name, label) |> head(20)
pull_spanish_speakers <- function(state, counties) {
get_acs(
geography = "tract",
variables = c(spanish_speakers = "B16001_005"),
state     = state,
county    = counties,
survey    = 'acs5',
year      = 2022,
geometry  = TRUE
)
}
kc_mo <- pull_spanish_speakers("MO", kc_counties$MO)
kc_mo
