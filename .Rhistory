library(rvest)
library(tidyverse)
web <- read_html("https://www2.ljworld.com/news/2002/apr/28/new_web_site_to/")
web
rvest::check_fields(web)
web$node
web$doc
html_elements(web)
web |> html_elements("section")
web |> html_elements("section") |> html_element("h2")
web |> html_elements("section") |> html_element("h4")
web |> html_elements("section") |> html_element("h3")
web |> html_elements("section") |> html_element("h1")
web |> html_elements("body") |> html_element("h1")
web |> html_elements("body")
web |> html_element("h1") |> html_text2()
web |> html_element("h2") |> html_text2()
web |> html_element("h3") |> html_text2()
web |> html_element("body") |> html_text2()
web |> html_element("main") |> html_text2()
web |> html_element("article") |> html_text2()
# What kinds of tags are on this page?
web |>
html_elements("*") |>        # select every element
html_name() |>               # extract tag names
table() |>
sort(decreasing = TRUE)
# See all links and their text together
links <- tibble(
text = web |> html_elements("a") |> html_text2(),
href = web |> html_elements("a") |> html_attr("href"),
class = web |> html_elements("a") |> html_attr("class")
)
links
page <- read_html("https://en.wikipedia.org/wiki/R_(programming_language)")
page
# Frequency table of all tags on the page
page |>
html_elements("*") |>
html_name() |>
table() |>
sort(decreasing = TRUE) |>
head(15)
# Get the intro paragraphs (before the table of contents)
# Wikipedia wraps the main body in a div with class "mw-parser-output"
intro <- page |>
html_elements(".mw-parser-output > p") |>  # direct <p> children only
html_text2()
# Print the first 3 paragraphs
intro[1:3]
# Extract every section heading
headings <- page |>
html_elements("h2, h3") |>
html_text2()
headings
library(rvest)
page <- read_html("https://www.marc.org")
# Get the tag frequency table
page |>
html_elements("*") |>
html_name() |>
table() |>
sort(decreasing = TRUE) |>
head(15)
# See all the navigation links — these lead to the real content
links <- tibble(
text = page |> html_elements("a") |> html_text2(),
href = page |> html_elements("a") |> html_attr("href")
) |>
filter(nchar(text) > 2)  # drop empty/icon links
links
links
# Clean view of all links, filtering out SVG noise
links |>
filter(!str_detect(text, "fill:|stroke:|encoding")) |>
print(n = 70)
