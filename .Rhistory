# Check what's actually in the master project listing PDF
# First let's see the file size to gauge complexity
library(httr2)
response <- request("https://www.marc.org/sites/default/files/2025-09/TIP-project-listing-26-30.pdf") |>
req_method("HEAD") |>
req_perform()
# Check file size
response |> resp_header("content-length")
# Also peek at one of the HTML document pages to see if it has
# structured data or just links to PDFs
amendment_page <- read_html("https://www.marc.org/document/2026-tip-2nd-quarter-amendment")
amendment_page |>
html_elements("main p, h2, h3, a") |>
html_text2() |>
(\(x) x[nchar(x) > 20])()
getwd()
library(httr2)
library(tibble)
# First, build a table of all the PDFs we already found
tip_pdfs <- tibble(
name = c(
"TIP_2026-2030_master",
"TIP_2026-2030_new_project_listing",
"TIP_2026-2030_project_listing",
"2025_obligated_projects",
"2024_obligated_projects",
"2026_1st_quarter_amendment"
),
url = c(
"https://www.marc.org/sites/default/files/2025-10/TIP_2026-2030.pdf",
"https://www.marc.org/sites/default/files/2025-09/TIP-new-project-listing-26-30.pdf",
"https://www.marc.org/sites/default/files/2025-09/TIP-project-listing-26-30.pdf",
"https://www.marc.org/sites/default/files/2025-12/2025-tip-obligated-projects.pdf",
"https://www.marc.org/sites/default/files/2024-12/2024-tip-obligated-projects.pdf",
"https://www.marc.org/sites/default/files/2025-12/2026-1st-quarter-tip-amendment.pdf"
)
)
# Create a folder to save them in
dir.create("tip_pdfs", showWarnings = FALSE)
# Download each one
tip_pdfs |>
purrr::pwalk(\(name, url) {
message("Downloading: ", name)
request(url) |>
req_perform() |>
resp_body_raw() |>
writeBin(con = paste0("tip_pdfs/", name, ".pdf"))
})
# Check file sizes to confirm downloads succeeded
file.info(list.files("tip_pdfs", full.names = TRUE)) |>
tibble::rownames_to_column("file") |>
dplyr::select(file, size)
